# Deployment configuration for docker-compose.deploy.yml.
#
#   cp .env.deploy.example .env.deploy   # .env.deploy is gitignored
#
# Runbook: docs/firm/DEPLOY.md

# --- required; the stack refuses to start without these -----------------------

# Not "firm". This database is never published to the host.
POSTGRES_PASSWORD=

# openssl rand -hex 32
# Anything that can reach the procurer's /pay-and-call can spend the Firm's
# money up to the caps, so a non-loopback bind requires this.
PROCURER_AUTH_TOKEN=

# Where the Firm gets paid. A wrong value here sends buyers' money to a stranger,
# which is why none of these three have defaults.
FIRM_PAYTO_ADDRESS=
FIRM_CHARGE_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736
FIRM_CHARGE_NETWORK=eip155:196

# --- payment path -------------------------------------------------------------

# `enforce` or the gateway refuses to bind a public interface: a public gateway
# in bypass mode does unlimited paid work for free while still paying vendors.
CHARGING_MODE=enforce

# TODO(unverified): route names and body shapes are confirmed only against our
# own fake facilitator, never the real OKX one. Unset means every paid call
# fails closed with a 402 — correct, but nobody can actually buy anything.
X402_FACILITATOR_URL=

# --- money switches; off means simulated, and simulations are labelled ---------

REAL_PAYMENTS_ENABLED=false
REAL_REFUNDS_ENABLED=false

# Passed at run time, never baked into an image, never committed.
FIRM_WALLET_KEY=

# Base-unit integers. Unset uses the procurer's built-in defaults.
PER_CALL_MAX_UNITS=
PER_TASK_MAX_UNITS=
DAILY_MAX_UNITS=
DAILY_REFUND_MAX_UNITS=

# Both are REQUIRED when REAL_PAYMENTS_ENABLED=true — the procurer refuses to
# start without them. Without both, the vendor chooses which asset and which
# chain we sign for, and a base-unit cap check cannot tell the difference.
#
# They also pin the decimal scale. 41 of the 47 live x402 vendors on this
# marketplace declare no extra.decimals, so requiring a declared scale would
# make almost all of them unhireable. Naming the asset and chain ourselves is
# what makes 6 decimals a fact rather than an assumption.
X402_ALLOWED_ASSETS=0x779ded0c9e1022225f8e0630b35a9b54be713736
X402_ALLOWED_NETWORKS=eip155:196

# Refunds. Both required before REAL_REFUNDS_ENABLED can do anything; the
# procurer refuses to guess the refund asset or network.
REFUND_CHAIN=
REFUND_TOKEN_CONTRACT=

# --- product ------------------------------------------------------------------

PRICING_MODE=TIERS
FIRM_PRICING_MODE=TIERS
EXPRESS_ENABLED=false
EXPRESS_JOB_TYPES=market_snapshot
# 0.1 USDT
EXPRESS_PRICE_UNITS=100000

VENDOR_INDEX_PATH=/app/data/vendor-index.json
ENABLE_TREASURY_BOOKS=false
DEFAULT_REFUND_ADDRESS=SIMULATED:refund-address

# Host port for the gateway. Only this service is exposed.
GATEWAY_PUBLIC_PORT=8790
