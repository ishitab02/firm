# --- storage ---
DATABASE_URL=postgresql://firm:firm@127.0.0.1:5432/firm
PORT=8790

# --- pricing ---
# TIERS is the conservative default and stays that way until the OKX
# variable-amount question (INTERFACES 1B) is closed by a human.
PRICING_MODE=TIERS

# --- seller-side charging ---
# "enforce" = paid tools are unreachable without a verified payment.
# Anything else = BYPASS: paid tools run unpaid, every response is stamped
# charging:"BYPASSED", and the server logs a warning on every call.
# Production MUST set this to enforce.
CHARGING_MODE=bypass

# Where The Firm gets paid. All three are required in enforce mode and none has
# a default: a wrong payTo sends the user's money to a stranger.
FIRM_PAYTO_ADDRESS=
FIRM_CHARGE_ASSET=
FIRM_CHARGE_NETWORK=
CHARGE_TIMEOUT_SECONDS=120

# TODO(unverified): the facilitator verification endpoint is not confirmed.
# While this is unset, enforce mode rejects every payment as unverifiable —
# which is the correct fail-closed behaviour, but it also means enforce mode
# cannot serve a paid call until a human supplies this.
X402_FACILITATOR_URL=

# --- tests ---
# Set to run the live payment-boundary test against a real Postgres.
GATEWAY_TEST_DATABASE_URL=
