# --- storage ---
DATABASE_URL=postgresql://firm:firm@127.0.0.1:5432/firm
PORT=8790
# Max connections in the process-wide pool.
PGPOOL_MAX=10

# --- pricing ---
# TIERS is the conservative default and stays that way until the OKX
# variable-amount question (INTERFACES 1B) is closed by a human.
PRICING_MODE=TIERS

# --- seller-side charging ---
# "enforce" = paid tools are unreachable without a verified payment.
# Anything else = BYPASS: paid tools run unpaid, every response is stamped
# charging:"BYPASSED", and the server logs a warning on every call.
# Production MUST set this to enforce.
CHARGING_MODE=bypass

# Where The Firm gets paid. All three are required in enforce mode and none has
# a default: a wrong payTo sends the user's money to a stranger.
FIRM_PAYTO_ADDRESS=
FIRM_CHARGE_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736
FIRM_CHARGE_NETWORK=eip155:196
CHARGE_TIMEOUT_SECONDS=120

# TODO(unverified): the facilitator verification endpoint is not confirmed.
# While this is unset, enforce mode rejects every payment as unverifiable —
# which is the correct fail-closed behaviour, but it also means enforce mode
# cannot serve a paid call until a human supplies this.
X402_FACILITATOR_URL=

# --- Firm Express (Service A) ---
# OFF by default and honestly so: INTERFACES §1A locks the Express job types
# only after live vendor-reliability testing (PLAN D4), which is gated on the
# human payment spike. While disabled, express_run returns EXPRESS_NOT_ENABLED
# and charges nothing. A human sets this once the pool is locked.
EXPRESS_ENABLED=false
# Comma-separated allow-list of offered job types (must map to a capability).
EXPRESS_JOB_TYPES=market_snapshot
# Fixed Express price in base units. Live listing: 0.1 USDT.
EXPRESS_PRICE_UNITS=100000
# Public URL a buyer replays against, published as the 402 challenge's top-level
# `resource.url`. Unset omits the object rather than guessing: a wrong replay URL
# is worse than an absent one.
FIRM_RESOURCE_URL=https://firm-gateway.fly.dev
# How long express_run waits for the synchronous result before returning PENDING.
EXPRESS_TIMEOUT_MS=60000

# --- Firm Projects (Service B) ---
# How long POST /projects waits for a completed deliverable/refund before
# returning PENDING with its free result_url. Capped at 110 seconds so the
# response stays inside the advertised 120-second x402 timeout.
PROJECTS_TIMEOUT_MS=90000

# --- tests ---
# Set to run the live payment-boundary test against a real Postgres.
GATEWAY_TEST_DATABASE_URL=
