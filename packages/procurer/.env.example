# --- storage ---
DATABASE_URL=postgresql://firm:firm@127.0.0.1:5432/firm
PORT=8787
PGPOOL_MAX=10

# --- spend caps, in base units (USDT/USDG: 6 decimals) ---
# Enforced BEFORE any payment. A call is reserved against these caps before the
# vendor is even probed.
PER_CALL_MAX=1000000
PER_TASK_MAX=5000000
DAILY_MAX=20000000
DAILY_REFUND_MAX=5000000

# --- real money switches (both default to off) ---
# REAL_PAYMENTS_ENABLED=true turns on the live x402 buyer flow in /pay-and-call.
REAL_PAYMENTS_ENABLED=false
# REAL_REFUNDS_ENABLED is separate on purpose: the refund transfer path uses a
# different wallet surface from the payment path. See docs/status/F1.md.
REAL_REFUNDS_ENABLED=false

# --- wallet ---
# The ONLY place in The Firm that holds a key. Never committed. Passed to the
# signer subprocess as EVM_PRIVATE_KEY and nowhere else.
FIRM_WALLET_KEY=

# --- buyer flow ---
# Chain RPC. Signing happens in-process (viem), so this is the only external
# dependency the money path has. X402_RPC_URL_<chainId> wins over the generic
# one; X Layer (196) falls back to https://rpc.xlayer.tech, the endpoint this
# repo's on-chain checks were run against. Any other chain must be set here
# rather than guessed.
X402_RPC_URL=
X402_RPC_URL_196=
# Escape hatch if a token's EIP-712 version cannot be derived. Rarely needed:
# candidates are read from the token and the vendor's `extra`, and every one is
# checked against the token's own DOMAIN_SEPARATOR() before use.
X402_TOKEN_VERSION_196=
# How long a signed authorization stays redeemable, and the clock-skew margin
# applied at both ends so a seller whose clock trails ours still accepts it.
X402_MIN_VALIDITY_SECONDS=600
X402_CLOCK_SKEW_SECONDS=60
# Comma-separated token contract addresses the procurer is allowed to pay in.
# Leave unset ONLY in simulation; a live run with this unset will pay in
# whatever asset the vendor names.
X402_ALLOWED_ASSETS=
SIGNER_TIMEOUT_MS=30000
VENDOR_TIMEOUT_MS=60000
# How long a reservation left behind by a crashed procurer may sit before
# another caller reclaims it. Must comfortably exceed VENDOR_TIMEOUT_MS.
# Signed rows are never reclaimed, however old.
RESERVATION_STALE_AFTER_SECONDS=900

# --- refund flow ---
# Refunds now leave the SAME wallet that pays vendors and receives customer
# payments (FIRM_WALLET_KEY's address), sent in-process as an ERC-20 transfer.
# Both values are required before a real refund will send; an unset value fails
# the refund closed rather than guessing the asset or network.
REFUND_CHAIN=196
REFUND_TOKEN_CONTRACT=0x779ded0c9e1022225f8e0630b35a9b54be713736
REFUND_TIMEOUT_MS=60000

# REQUIRED whenever REAL_REFUNDS_ENABLED=true, and checked against the address
# derived from FIRM_WALLET_KEY. This does not guard an untrusted account any
# more — the key is ours. It guards the wrong key being deployed: a staging or
# personal key reaching production would refund real customers from an
# unintended wallet with no log line looking out of place.
REFUND_FROM_ADDRESS=

# NOTE: unlike a payment, a refund is a transaction WE broadcast, so this wallet
# must hold native gas (OKB on X Layer). Checked before sending; an unfunded
# wallet refuses with a clear message instead of an opaque revert at the moment
# the guarantee is invoked.

# --- tests ---
# Set to run the reservation/cap concurrency tests against a real Postgres.
PROCURER_TEST_DATABASE_URL=
